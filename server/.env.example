# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/maxxarena?schema=public"

# Server Configuration
PORT=5000
CLIENT_URL="http://localhost:5173"

# JWT Secrets
JWT_ACCESS_SECRET="generate_a_secure_random_string_for_access"
JWT_REFRESH_SECRET="generate_a_secure_random_string_for_refresh"

# Tokens Expiration
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth (For Step 8)
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
